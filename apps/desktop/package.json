{
  "name": "@cooler-monitor/desktop",
  "version": "1.1.0",
  "description": "COOLER MONITOR BR - Desktop Application",
  "author": "COOLER MONITOR BR",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev.mjs",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release": "electron-builder --config electron-builder.json5 --publish always",
    "pack": "electron-builder --config electron-builder.json5 --dir"
  },
  "dependencies": {
    "@cooler-monitor/core": "*",
    "@cooler-monitor/hardware": "*",
    "@cooler-monitor/database": "*",
    "@cooler-monitor/shared": "*",
    "@cooler-monitor/ui": "*",
    "@cooler-monitor/utils": "*",
    "electron-store": "^8.1.0",
    "electron-log": "^5.0.0",
    "ws": "^8.16.0",
    "electron-updater": "^6.1.0",
    "systeminformation": "^5.21.0",
    "active-win": "^8.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.56.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.1.0",
    "zustand": "^4.4.0",
    "@tanstack/react-query": "^5.17.0",
    "chart.js": "^4.4.0",
    "react-chartjs-2": "^5.2.0"
  }
}
